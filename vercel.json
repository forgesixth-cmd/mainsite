{
  "rewrites": [
    {
      "source": "/forgeinvoice",
      "destination": "https://forgeinvoice.vercel.app/forgeinvoice"
    },
    {
      "source": "/forgeinvoice/:path*",
      "destination": "https://forgeinvoice.vercel.app/forgeinvoice/:path*"
    },
    {
      "source": "/forgefitness",
      "destination": "https://forgefitness.vercel.app"
    },
    {
      "source": "/forgefitness/:path*",
      "destination": "https://forgefitness.vercel.app/:path*"
    },
    {
      "source": "/personal-expense-tracker",
      "destination": "https://sixthforge-personal-expense-tracker.vercel.app/personal-expense-tracker"
    },
    {
      "source": "/personal-expense-tracker/:path*",
      "destination": "https://sixthforge-personal-expense-tracker.vercel.app/personal-expense-tracker/:path*"
    },
    {
      "source": "/myforgefitness",
      "destination": "https://myforgefitness.vercel.app/myforgefitness"
    },
    {
      "source": "/myforgefitness/:path*",
      "destination": "https://myforgefitness.vercel.app/myforgefitness/:path*"
    }
  ]
}
